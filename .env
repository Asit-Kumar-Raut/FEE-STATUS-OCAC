CREATE DATABASE IF NOT EXISTS ocac;
USE ocac;

-- Admin Registration Table (Based on your custom fields)
CREATE TABLE admins (
    admin_id VARCHAR(50) PRIMARY KEY,
    name VARCHAR(100),
    username VARCHAR(50) UNIQUE,
    email VARCHAR(100) UNIQUE,
    contact VARCHAR(15),
    password VARCHAR(255)
);

-- Counselor Registration Table
CREATE TABLE counselors (
    counselor_id VARCHAR(50) PRIMARY KEY,
    name VARCHAR(100),
    username VARCHAR(50) UNIQUE,
    contact VARCHAR(15),
    password VARCHAR(255),
    status VARCHAR(20) DEFAULT 'Pending'
);

-- Student Registration Table
CREATE TABLE students (
    student_id VARCHAR(50) PRIMARY KEY,
    name VARCHAR(100),
    username VARCHAR(50) UNIQUE,
    phonenumber VARCHAR(15),
    emailid VARCHAR(100) UNIQUE,
    course VARCHAR(100),
    academic_year VARCHAR(20),
    semester VARCHAR(20),
    status VARCHAR(20) DEFAULT 'Pending',
    total_fee INT DEFAULT 100000,
    paid_amount INT DEFAULT 0,
    pending_amount INT DEFAULT 100000
);

-- Student Feedback Forms Table
CREATE TABLE student_feedback (
    id INT AUTO_INCREMENT PRIMARY KEY,
    student_id VARCHAR(50),
    name VARCHAR(100),
    feedback TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Counselor Feedback/Correction Notices Table
CREATE TABLE counselor_feedback (
    id INT AUTO_INCREMENT PRIMARY KEY,
    counselor_id VARCHAR(50),
    counselor_name VARCHAR(100),
    student_id VARCHAR(50),
    message TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);